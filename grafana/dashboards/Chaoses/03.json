            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 50,
            "barWidthFactor": 0.6,
            "showPoints": "auto",
            "pointSize": 1,
            "spanNulls": false,
            "gradientMode": "none",
            "insertNulls": false,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            },
