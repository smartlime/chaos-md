            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "barAlignment": 0,
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
