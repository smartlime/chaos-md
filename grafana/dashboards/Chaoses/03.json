      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds}"
          },
          "expr": "sum by (status) (rate(ydb_api_grpc_response_count{container=\"ydb-dynamic\",database=~\"$database\",status!=\"SUCCESS\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
