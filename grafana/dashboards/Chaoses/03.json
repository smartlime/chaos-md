    {
      "id": 13,
      "type": "timeseries",
      "title": "Disk IOps by host",
      "datasource": {
        "type": "prometheus",
        "uid": "${ds}"
      },
      "gridPos": {
        "x": 16,
        "y": 10,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "auto",
            "pointSize": 3,
            "spanNulls": false,
            "gradientMode": "none",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            },
            "scaleDistribution": {
              "type": "linear"
            },
